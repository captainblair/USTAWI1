# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Docker: USE_POSTGIS=true + postgis://...
# Local Windows without GDAL: USE_POSTGIS=false
# Quick local dev without Postgres: USE_SQLITE=true
USE_POSTGIS=true
USE_SQLITE=false
DATABASE_URL=postgis://ustawi:ustawi@localhost:5432/ustawi

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# CORS (comma-separated origins for Vercel frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Africa's Talking (SMS/OTP) — leave blank to use console OTP in development
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=USTAWI

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# Email (password reset)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Ustawi <noreply@ustawikenya.com>
FRONTEND_PASSWORD_RESET_URL=http://localhost:3000/reset-password

# M-Pesa Daraja — leave blank for dev-mode STK simulation
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:8001/api/v1/payments/webhooks/mpesa/
MPESA_ENVIRONMENT=sandbox
